# ---- Supabase ----
NEXT_PUBLIC_SUPABASE_URL=https://YOUR_PROJECT.supabase.co
NEXT_PUBLIC_SUPABASE_ANON_KEY=your-anon-key
SUPABASE_SERVICE_ROLE_KEY=your-service-role-key   # server-only, never expose

# ---- App ----
NEXT_PUBLIC_SITE_URL=http://localhost:3000

# ---- Email (magic-link invites are sent via Supabase Auth by default) ----
# Optional transactional email provider for estimate notifications (v1 uses Supabase;
# swap in Resend/SendGrid here in production)
RESEND_API_KEY=

